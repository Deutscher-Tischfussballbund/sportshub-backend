# Copy to `.env` (same directory as docker-compose.yaml) and fill in.
# Docker Compose auto-loads `.env` for ${...} interpolation in the compose file.
# `.env` is git-ignored; this example is committed as documentation.

# --- Required (compose fails fast without these) ---
# Password for the sportshub MySQL database (used by both the app and the db container).
SPORTSHUB_DB_PASSWORD=
# Keycloak issuer — must equal the `iss` claim in tokens (string match, no network call;
# mind the scheme/host). Prod: https://id.dtfb.de/realms/dtfb. Local dev against the dev
# Keycloak: http://localhost:8084/realms/dtfb (the browser logs in via localhost:8084).
KEYCLOAK_ISSUER_URI=https://id.dtfb.de/realms/dtfb

# --- Recommended on the first deploy ---
# dtfb_id (Keycloak username) granted GLOBAL ADMIN on startup. Idempotent; can stay set.
SPORTSHUB_BOOTSTRAP_ADMIN_DTFB_ID=
# Allowed CORS origin(s) for the admin console — the exact scheme://host[:port] the browser
# uses. Comma-separated for several (e.g. https://admin.dtfb.de,https://admin.stage.dtfb.de).
SPORTSHUB_CORS_ALLOWED_ORIGINS=https://admin.dtfb.de

# --- Optional (sensible defaults live in docker-compose.yaml) ---
# DB username (default: sportshub)
#SPORTSHUB_DB_USER=sportshub
# JWKS endpoint the backend fetches signing keys from — must be reachable FROM the container
# (unlike the issuer, this is an actual network call). Default = the `keycloak` service on the
# shared `dtfb` network (full prod stack). Local dev with the dev Keycloak on the host instead:
#   KEYCLOAK_JWK_SET_URI=http://host.docker.internal:8084/realms/dtfb/protocol/openid-connect/certs
#KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/dtfb/protocol/openid-connect/certs
# Image tag to run; pin a release for prod, e.g. 0.1.0 (default: latest)
#SPORTSHUB_TAG=latest
